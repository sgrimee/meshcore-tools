# meshcore-tools configuration
# Copy to ~/.config/meshcore-tools/config.toml and edit for your setup.
# All keys are optional — the app uses sensible defaults when absent.

[general]
# Default region for the letsmesh API and node database updates.
# Can also be set with the --region CLI flag (saved automatically on first use).
region = "LUX"

[filtering]
# Node names or public-key prefixes to hide in the monitor.
# Useful for suppressing address-collision ghosts or noisy nodes.
blacklist = []

[packet_source]
# Packet source for the monitor tab: "letsmesh" (default) or "mqtt".
type = "letsmesh"
# Which [mqtt.<name>] profile below to use when type = "mqtt".
# Defaults to "luxmesh" — the public live.luxmesh.lu broker, which works
# with no [mqtt.luxmesh] table at all if you don't need to override it.
mqtt_server = "luxmesh"

# MQTT server profiles — only used when packet_source.type = "mqtt".
# Define as many as you like and switch between them via mqtt_server above.
# Credentials (if a broker requires them) go in secrets.toml instead,
# keyed by broker hostname — see secrets.toml.sample.
[mqtt.luxmesh]
broker = "live.luxmesh.lu"
port = 1883
topic = "meshcore/LUX/+/packets"

# [mqtt.home]
# broker = "localhost"
# port = 1883
# topic = "meshcore/raw"
