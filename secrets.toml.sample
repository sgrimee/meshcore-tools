# meshcore-tools secrets
# Copy to ~/.config/meshcore-tools/secrets.toml and set permissions to 600:
#   chmod 600 ~/.config/meshcore-tools/secrets.toml
#
# WARNING: Passwords are stored in plaintext. Protect this file.
# The app creates and maintains this file automatically with 600 permissions
# when you save a password through the login dialog — manual editing is optional.

# Fallback password pre-filled for all login prompts.
# default_password = "your-default-password"

# Per-repeater passwords, keyed by public key (full or prefix).
# These take precedence over default_password for their specific node.
# [passwords]
# "abcdef1234abcdef1234abcdef1234abcdef1234abcdef1234abcdef1234abcd" = "repeater-pw"

# Channel keys for GroupText/GroupData decryption (32-char hex = 16-byte AES key).
# Hashtag channels with no key derive their key automatically from the name.
# [channels]
# "Public" = "8b3387e9c5cdea6ac9e5edbaa115cd72"
# "#wardriving" = "e3c26491e9cd321e3a6be50d57d54acf"
# "MyChannel" = "52d21b5e68a130279cce6b64c0f8bcd4"
